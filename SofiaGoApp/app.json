{
  "expo": {
    "name": "SofiaGo",
    "slug": "SofiaGoApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon-new.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon-new.png",
        "backgroundColor": "#ffffff"
      },
      "notification": {
        "icon": "./assets/app-icon-new.png",
        "color": "#0F766E"
      },
      "package": "com.iliyanvezirski.SofiaGoApp"
    },
    "web": {
      "favicon": "./assets/app-icon-new.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/app-icon-new.png",
          "color": "#0F766E",
          "defaultChannel": "transit-arrivals-v2"
        }
      ],
      "expo-dev-client",
      "@maplibre/maplibre-react-native",
      "expo-asset",
      "expo-font",
      "expo-background-task"
    ],
    "extra": {
      "eas": {
        "projectId": "c4a2bbe7-4780-4338-a307-908bae73f2fc"
      }
    }
  }
}
